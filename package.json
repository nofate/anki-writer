{
  "name": "anki-apkg-writer",
  "version": "1.1.0",
  "description": "Streaming TypeScript implementation for Anki .apkg file generation",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:meta": "esbuild src/index.ts --bundle --platform=node --format=esm --outdir=dist-meta --metafile=meta.json",
    "dev": "tsc --watch",
    "example": "tsx example.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "anki",
    "apkg",
    "flashcards",
    "spaced-repetition",
    "streaming",
    "typescript"
  ],
  "author": "https://github.com/nofate/",
  "license": "MIT",
  "dependencies": {
    "fflate": "^0.8.2",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "esbuild": "^0.25.9",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
